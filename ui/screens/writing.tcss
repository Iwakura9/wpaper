WritingScreen {
    align: center top;
}

#writing_screen {
    align: center top;
    width: 100%;
    height: 100%;
}

#header {
    width: 100%;
    max-width: 140;
    height: 4;
    align: center middle;
}

#note_title {
    color: white;
    text-style: bold;
    content-align: center middle;
}

#note_date {
    color: $text-muted;
    text-style: italic;
    content-align: center middle;
}

#note_body {
    width: 100%;
    max-width: 140;
}
